# Environment configuration
ENVIRONMENT=development

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_RESOURCE_GROUP=rg-clustering-dev
AZURE_LOCATION=eastus

# Storage Configuration
AZURE_STORAGE_ACCOUNT=your-storage-account
AZURE_STORAGE_CONTAINER=clustering-data
AZURE_STORAGE_CONNECTION_STRING=your-connection-string

# Machine Learning Configuration
AZURE_ML_WORKSPACE_NAME=ml-clustering-dev
DEFAULT_ALGORITHM=deep_embedding
MAX_DIMENSIONS=10000

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database Configuration
COSMOS_DB_CONNECTION_STRING=your-cosmos-connection-string
COSMOS_DB_DATABASE=clustering
COSMOS_DB_CONTAINER=jobs

# Monitoring Configuration
ENABLE_MONITORING=true
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-app-insights-key
APPLICATIONINSIGHTS_CONNECTION_STRING=your-app-insights-connection-string

# MLflow Configuration
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=clustering_experiments

# Performance Configuration
BATCH_SIZE=1024
MAX_EPOCHS=100
LEARNING_RATE=0.001
N_JOBS=-1
USE_GPU=true

# Security Configuration
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_TENANT_ID=your-tenant-id

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/clustering.log

# Data Configuration
DATA_DIR=data
MODELS_DIR=models
RESULTS_DIR=results

# Clustering Configuration
MIN_CLUSTER_SIZE=5
MAX_CLUSTERS=50
SIMILARITY_THRESHOLD=0.8
